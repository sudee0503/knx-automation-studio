<UserControl x:Class="Sude.Views.UserViews.UC_DeviceSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"              
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Sude.Views.UserViews"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#F8E8EE">
    <Grid>
        <Button Command="{Binding LogoutCommand}" 
                Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                Background="White" BorderThickness="0" 
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" 
                ToolTip="Sistemden Çıkış Yap">
            <materialDesign:PackIcon Kind="Logout" Foreground="#BB2248" Width="25" Height="25"/>
        </Button>
        
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">

            <materialDesign:PackIcon Kind="Devices" Width="60" Height="60" Foreground="#BB2248" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="CİHAZ SEÇİMİ" FontSize="26" FontWeight="Bold" Foreground="#3A0519" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Lütfen test etmek istediğiniz cihazı seçin" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <ComboBox materialDesign:HintAssist.Hint="Test Edilecek Cihaz (Tür)" 
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                      FontSize="16" Margin="0,0,0,30" Foreground="#3A0519"
                      ItemsSource="{Binding Devices}"
                      DisplayMemberPath="DeviceType"
                      SelectedItem="{Binding SelectedDevice}"/>

            <Border Background="White" CornerRadius="10" Padding="10" Margin="0,0,0,30" 
                    Height="200" Width="300" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#BB2248" BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
                </Border.Effect>

                <Grid>
                    <TextBlock Text="Cihaz Seçildiğinde Görseli Burada Belirecektir" 
                               Foreground="LightGray" TextWrapping="Wrap" TextAlignment="Center" 
                               VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDeviceImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Image Source="{Binding SelectedDeviceImage}" Stretch="Uniform" />
                </Grid>
            </Border>

            <Button Content="CİHAZ KONTROLÜNE GEÇ" 
                    Command="{Binding ContinueToControlCommand}" 
                    Background="#BB2248" BorderBrush="#BB2248" Foreground="White" 
                    Height="50" FontSize="16" FontWeight="Bold" Cursor="Hand"
                    materialDesign:ButtonAssist.CornerRadius="10"/>

        </StackPanel>
    </Grid>
</UserControl>
