<UserControl x:Class="Sude.Views.UC_Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Sude.Views">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="360" Margin="0,0,0,50">

            <Image Source="/Sude;component/Resources/MutlusanLogo.png" Width="200" Height="80" HorizontalAlignment="Center" Margin="0,20,0,10" />
            <TextBlock Text="KNX OTOMASYON" FontSize="30" FontWeight="Bold" Foreground="#757F8A" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBox materialDesign:HintAssist.Hint="Kullanıcı Adı" 
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     FontSize="16" Margin="0,0,0,25" Foreground="#B3B8BF"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:TextFieldAssist.HasClearButton="True"/>

            <PasswordBox x:Name="TxtPassword" 
                         materialDesign:HintAssist.Hint="Şifre" 
                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                         FontSize="16" Margin="0,0,0,50" Foreground="#B3B8BF"
                         materialDesign:TextFieldAssist.HasClearButton="True"/>

            <Button Content="GİRİŞ YAP" Margin="30,0,30,20"
                    Command="{Binding LoginCommand}" 
                    CommandParameter="{Binding ElementName=TxtPassword}"
                    Background="#BB2248" BorderBrush="#BB2248" Foreground="#B3B8BF" 
                    Height="55" FontSize="18" FontWeight="Bold" Cursor="Hand"
                    materialDesign:ButtonAssist.CornerRadius="10"/>
        </StackPanel>
    </Grid>
</UserControl>