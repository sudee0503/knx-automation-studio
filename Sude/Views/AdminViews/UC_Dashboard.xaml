<UserControl x:Class="Sude.Views.AdminViews.UC_Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d"
             Background="#F8E8EE"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="15,20,15,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#BB2248" CornerRadius="15" Margin="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Toplam Cihaz" Foreground="#F8E8EE" FontSize="16" 
                               FontWeight="SemiBold" HorizontalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="{Binding StatBox1}" Foreground="#F8E8EE" FontSize="42" 
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#BB2248" CornerRadius="15" Margin="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Aktif Kullanıcı" Foreground="#F8E8EE" FontSize="16" 
                               FontWeight="SemiBold" HorizontalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="{Binding StatBox2}" Foreground="#F8E8EE" FontSize="42" 
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#BB2248" CornerRadius="15" Margin="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Bu Hafta Yapılan İşlem" Foreground="#F8E8EE" FontSize="16" 
                               FontWeight="SemiBold" HorizontalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="{Binding StatBox4}" Foreground="#F8E8EE" FontSize="42" 
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="#BB2248" CornerRadius="15" Margin="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Toplam İşlem" Foreground="#F8E8EE" FontSize="16" 
                               FontWeight="SemiBold" HorizontalAlignment="Center" Opacity="0.9"/>
                    <TextBlock Text="{Binding StatBox3}" Foreground="#F8E8EE" FontSize="42" 
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="15,10,15,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.7*"/>
                <ColumnDefinition Width="0.3*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Background="#F8E8EE" UniformCornerRadius="15" Margin="10">
                <materialDesign:Card.Effect>
                    <DropShadowEffect Color="#BB2248" BlurRadius="20" ShadowDepth="2" Opacity="0.1"/>
                </materialDesign:Card.Effect>

                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- GRAFİK BAŞLIĞI VE FİLTRE BUTONLARI -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Sol Taraf: İkon ve Dinamik Başlık -->
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <materialDesign:PackIcon Kind="ChartBar" Width="25" Height="25" Foreground="#BB2248" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ChartTitle}" FontSize="18" FontWeight="Bold" Foreground="#BB2248" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Sağ Taraf: Zaman Aralığı Butonları -->
                        <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                            <Button Content="Hafta" Command="{Binding ChangeChartPeriodCommand}" CommandParameter="Week" 
                                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#757F8A" Height="25" Padding="5,0" Margin="0,0,5,0"/>

                            <Button Content="Ay" Command="{Binding ChangeChartPeriodCommand}" CommandParameter="Month" 
                                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#757F8A" Height="25" Padding="5,0" Margin="0,0,5,0"/>

                            <Button Content="Yıl" Command="{Binding ChangeChartPeriodCommand}" CommandParameter="Year" 
                                    Style="{StaticResource MaterialDesignFlatButton}" Foreground="#757F8A" Height="25" Padding="5,0"/>
                        </StackPanel>
                    </Grid>

                    <lvc:CartesianChart Grid.Row="1" Series="{Binding WeeklySeries}" LegendLocation="None" Margin="10">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Tarihler" Labels="{Binding WeeklyLabels}" LabelsRotation="-45">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1" IsEnabled="False"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="İşlem Sayısı" LabelFormatter="{Binding YFormatter}" MinValue="0"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1" Background="#F8E8EE" UniformCornerRadius="15" Margin="10">
                <materialDesign:Card.Effect>
                    <DropShadowEffect Color="#BB2248" BlurRadius="20" ShadowDepth="2" Opacity="0.1"/>
                </materialDesign:Card.Effect>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <materialDesign:PackIcon Kind="History" Width="25" Height="25" Foreground="#BB2248" VerticalAlignment="Center"/>
                        <TextBlock Text="Son İşlemler" FontSize="18" FontWeight="Bold" Foreground="#BB2248" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,5,0,0">
                        <ItemsControl ItemsSource="{Binding RecentLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F8E8EE" BorderThickness="0,0,0,1" Padding="0,8">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <materialDesign:PackIcon Kind="RecordCircleOutline" Foreground="#757F8A" 
                                                                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding IslemAciklamasi}" FontSize="13" 
                                                           Foreground="#3A0519" FontWeight="Medium" TextWrapping="Wrap"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Tarihi, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" FontSize="11" Foreground="Gray" Margin="25,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>