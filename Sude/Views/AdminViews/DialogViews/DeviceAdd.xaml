<UserControl x:Class="Sude.Views.AdminViews.DialogViews.DeviceAdd"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F8E8EE"
             Height="550" Width="850">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Height="50" Margin="0,0,0,10">
            <materialDesign:PackIcon Kind="ImportantDevices" Width="30" Height="30" Margin="10,10,0,0" Foreground="#BB2248"/>
            <TextBlock Text="Yeni Cihaz ve Test Senaryosu Ekle" FontSize="20" FontWeight="Bold" Foreground="#BB2248" Margin="15,10,20,10"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,10,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="45*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="55*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBox materialDesign:HintAssist.Hint="Cihaz ID * (1-255 Arası)" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         FontSize="15" Margin="0,0,0,15" 
                         Text="{Binding DeviceId, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBox materialDesign:HintAssist.Hint="Cihaz Adı / Türü *" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         FontSize="15" Margin="0,0,0,15" 
                         Text="{Binding DeviceType, UpdateSourceTrigger=PropertyChanged}"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding MainImagePath}" IsReadOnly="True" materialDesign:HintAssist.Hint="Cihazın Ana Görseli *" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    <Button Grid.Column="1" Content="..." Command="{Binding SelectMainImageCommand}" Margin="10,0,0,0" Style="{StaticResource MaterialDesignFlatDarkBgButton}" Background="#BB2248" BorderBrush="#BB2248"/>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding SelectedProjectPath}" IsReadOnly="True" materialDesign:HintAssist.Hint="EITT Proje Dosyası (.ctl) *" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    <Button Grid.Column="1" Content="..." Command="{Binding SelectProjectCommand}" Margin="10,0,0,0" Style="{StaticResource MaterialDesignFlatDarkBgButton}" Background="#BB2248" BorderBrush="#BB2248"/>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding SelectedVideoPath}" IsReadOnly="True" materialDesign:HintAssist.Hint="Bekleme Ekranı Videosu (.mp4)" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    <Button Grid.Column="1" Content="..." Command="{Binding SelectVideoCommand}" Margin="10,0,0,0" Style="{StaticResource MaterialDesignFlatDarkBgButton}" Background="#BB2248" BorderBrush="#BB2248"/>
                </Grid>
            </StackPanel>

            <Border Grid.Column="2" BorderBrush="#BB2248" BorderThickness="2" CornerRadius="10" Padding="15" Background="#F0D9E0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Cihaz Test Senaryosu" FontSize="16" FontWeight="Bold" Foreground="#BB2248"/>
                        <TextBlock Text="Bu cihaza özel test komutlarını sırasıyla ekleyin." FontSize="12" Foreground="DarkGray" TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TestSteps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="8" Padding="10" Margin="0,0,5,10" BorderBrush="LightGray" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding StepOrder, StringFormat={}{0}.}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="#BB2248"/>

                                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="5" ClipToBounds="True" Margin="0,0,10,0" BorderBrush="LightGray" BorderThickness="1">
                                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Border>

                                            <TextBox Grid.Column="2" Text="{Binding InstructionText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Komut/Yönlendirme yazın..." Margin="5,0,10,0" VerticalAlignment="Center" FontSize="13"/>

                                            <Button Grid.Column="3" Content="Resim Seç" Command="{Binding SelectImageCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#757F8A" BorderBrush="#757F8A" Height="30" Padding="8,0" Margin="0,0,10,0" FontSize="12" VerticalAlignment="Center"/>

                                            <Button Grid.Column="4" Command="{Binding RemoveCommand}" Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" Background="#D32F2F" BorderThickness="0" Width="28" Height="28" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <materialDesign:PackIcon Kind="Delete" Foreground="White" Width="16" Height="16"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Content="+ YENİ ADIM EKLE" Command="{Binding AddNewStepCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#BB2248" FontWeight="Bold" FontSize="14" Margin="0,10,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <Button Content="CİHAZI VE SENARYOYU KAYDET" Style="{StaticResource MaterialDesignRaisedButton}" Background="#BB2248" BorderBrush="#BB2248" Height="45" FontWeight="Bold" Command="{Binding SaveCommand}" />
            <Button Content="İptal" Style="{StaticResource MaterialDesignFlatButton}" Foreground="Gray" Margin="0,10,0,0" Command="{Binding CancelCommand}"/>
        </StackPanel>

    </Grid>
</UserControl>