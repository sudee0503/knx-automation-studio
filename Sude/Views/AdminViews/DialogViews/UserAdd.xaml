<UserControl x:Class="Sude.Views.AdminViews.DialogViews.UserAdd"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Sude.Views.AdminViews.DialogViews"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="325" Background="#F8E8EE" Width="332">

    <Grid Margin="25">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal" Height="50">
                <materialDesign:PackIcon Kind="AccountPlus" Width="30" Height="30" Margin="20,10,0,0"
                                         Foreground="#BB2248" HorizontalAlignment="Center"/>
                <TextBlock Text="Yeni Kullanıcı Kaydı" FontSize="20" FontWeight="Bold"
                           Foreground="#BB2248" HorizontalAlignment="Center" Margin="20,10,0,10"/>
            </StackPanel>

            <TextBox materialDesign:HintAssist.Hint="Kullanıcı Adı"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     FontSize="15" Margin="50,0,50,15"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:TextFieldAssist.HasClearButton="True"/>

            <TextBox materialDesign:HintAssist.Hint="Şifre"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     FontSize="15" Margin="50,0,50,40"
                     Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:TextFieldAssist.HasClearButton="True"/>

            <Button Content="KULLANICIYI KAYDET"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#BB2248" BorderBrush="#BB2248"
                    Height="45" FontWeight="Bold"
                    Command="{Binding SaveCommand}" />

            <Button Content="İptal"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="Gray" Margin="0,10,0,0"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
