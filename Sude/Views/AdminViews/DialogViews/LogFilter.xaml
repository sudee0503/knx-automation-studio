<UserControl x:Class="Sude.Views.AdminViews.DialogViews.LogFilter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" Background="#F8E8EE" Width="400" Height="400">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Kayıtları Filtrele" FontSize="20" FontWeight="Bold" 
                   Foreground="#BB2248" HorizontalAlignment="Center" Margin="0,20,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">

            <ComboBox materialDesign:HintAssist.Hint="İşlemi Yapan Kullanıcı" 
              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
              ItemsSource="{Binding Users}" DisplayMemberPath="Username" 
              SelectedValuePath="Username" SelectedValue="{Binding FilterLog.SecilenKullanici}"
              FontSize="16" Margin="0,0,0,2"/>

            <ComboBox materialDesign:HintAssist.Hint="Yapılan İşlem Türü" 
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                      ItemsSource="{Binding IslemTurleri}"
                      DisplayMemberPath="TType" 
                      SelectedValuePath="Id"
                      SelectedValue="{Binding FilterLog.SecilenIslemId}"
                      FontSize="16" Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <DatePicker Grid.Column="0" 
                    materialDesign:HintAssist.Hint="Başlangıç"
                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                    SelectedDate="{Binding FilterLog.FiltreBaslangic}"
                    Margin="0,0,5,0"/>

                <DatePicker Grid.Column="1" 
                    materialDesign:HintAssist.Hint="Bitiş"
                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                    SelectedDate="{Binding FilterLog.FiltreBitis}"
                    Margin="5,0,0,0"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Button Content="Bugün" Style="{StaticResource MaterialDesignFlatButton}" 
                        Command="{Binding QuickFilterCommand}" CommandParameter="Today" FontSize="12"/>
                <Button Content="Son 7 Gün" Style="{StaticResource MaterialDesignFlatButton}" 
                        Command="{Binding QuickFilterCommand}" CommandParameter="LastWeek" FontSize="12"/>

                <Button Content="SIFIRLA" Style="{StaticResource MaterialDesignFlatButton}" 
                        Command="{Binding ClearFilterCommand}" Foreground="#D32F2F" FontSize="12" FontWeight="Bold"/>
            </StackPanel>

            <Button Content="FİLTRELE"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#BB2248" BorderBrush="#BB2248"
                    Height="45" FontWeight="Bold"
                    Command="{Binding SaveCommand}" />

            <Button Content="İptal"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="Gray" Margin="0,10,0,0"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>