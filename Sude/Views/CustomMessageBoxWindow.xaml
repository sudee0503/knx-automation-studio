<Window x:Class="Sude.Views.CustomMessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Mesaj" SizeToContent="WidthAndHeight" MinWidth="400" MaxWidth="500" MinHeight="200"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" Background="Transparent">

    <materialDesign:Card UniformCornerRadius="15" Background="#F8E8EE" Margin="15">
        <materialDesign:Card.Effect>
            <DropShadowEffect Color="#BB2248" BlurRadius="20" Opacity="0.3" ShadowDepth="2"/>
        </materialDesign:Card.Effect>
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                <materialDesign:PackIcon x:Name="IconMsg" Kind="AlertCircle" Width="30" Height="30" 
                                         Foreground="#BB2248" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTitle" Text="Uyarı Başlığı" FontSize="16" FontWeight="Bold" 
                           Foreground="#3A0519" Margin="15,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="TxtMessage" Grid.Row="1" Text="Buraya hata veya bilgi mesajı gelecek..." 
                       FontSize="12" Foreground="#3A0519" FontWeight="Medium" TextWrapping="Wrap" 
                       Margin="10,10,10,25" VerticalAlignment="Center" LineHeight="22"/>

            <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Content="HAYIR" Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="Gray" FontWeight="Bold" Margin="0,0,10,0" Click="BtnCancel_Click" 
                        Visibility="Collapsed"/>

                <Button x:Name="BtnOk" Content="TAMAM" Style="{StaticResource MaterialDesignRaisedButton}" 
                        Background="#BB2248" BorderBrush="#BB2248" FontWeight="Bold" Height="30" MinWidth="100" 
                        Click="BtnOk_Click"/>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</Window>